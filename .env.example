# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# These belong on a BACKEND server, not the front end.
# The generation backend (server/index.mjs, run with `npm run server`) reads:
ANTHROPIC_API_KEY=your_anthropic_key_here   # lore generation (Claude)
GOOGLE_API_KEY=your_google_gemini_key_here  # face -> character art (nano-banana)
# Optional backend config:
# PORT=8787
# ALLOW_ORIGIN=http://localhost:5173   # comma-separated allowlist, or *
# SIDEQUEST_API_TOKEN=                  # if set, paid endpoints require this bearer token
# RATE_MAX=30                           # max paid requests per IP per window
# RATE_WINDOW_MS=60000
# MAX_GENERATIONS_PER_DAY=500           # hard daily ceiling (bounds worst-case spend)
# UPSTREAM_TIMEOUT_MS=60000

# Still to be wired (checkout + fulfillment — see docs/SideQuest_Backend_Spec.md):
STRIPE_SECRET_KEY=your_stripe_secret_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
PRODIGI_API_KEY=your_print_provider_key_here

# ---------------------------------------------------------------------------
# FRONTEND (Vite) — safe to expose; points the app at the backend above.
# Without this, the app runs in offline demo mode (themed fallback decks,
# procedural art). Set it to enable live AI lore + face->character art.
# ---------------------------------------------------------------------------
# VITE_API_BASE=http://localhost:8787
# VITE_API_TOKEN=            # only if the backend sets SIDEQUEST_API_TOKEN
